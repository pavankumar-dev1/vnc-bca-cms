# Copy this file to `.env` for local development and fill in real values.
# On Railway, set these same variables under Project -> Variables.

# Flask environment: "development" or "production"
FLASK_ENV=production

# A long, random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=c46f263c86d2f16f99c9c2847e3f9ba0ec32e7ec45b112d9cf183730dba120cf

# --- First-run admin bootstrap ---
# These are only used ONCE, to create the first admin user in the database
# when the app starts up and no admin user exists yet. After that, admin
# credentials live in the database and are managed via the admin panel's
# "Change Password" page (or the `flask create-admin` CLI command).
ADMIN_USERNAME=admin

# Werkzeug password hash for the admin account (NOT the plaintext password).
# Generate one with:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('your-strong-password'))"
ADMIN_PASSWORD_HASH=pbkdf2:sha256:...

# --- Optional: developer account ---
# The developer account can do everything the admin account can, PLUS it is
# the only account allowed to hide the "developer credit" button on the
# public site. Leave DEVELOPER_PASSWORD_HASH unset if you don't want this
# account created - you can also add one later with `flask create-admin`
# (it will ask for a role).
DEVELOPER_USERNAME=developer
DEVELOPER_PASSWORD_HASH=

# Path to the SQLite database file. Defaults to instance/app.db if unset.
# DATABASE_PATH=instance/app.db

# Optional: full SQLAlchemy database URL (overrides DATABASE_PATH). Use this
# to point at Postgres/MySQL instead of SQLite in production, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=

# Set to "true" when serving over HTTPS (recommended in production, e.g. Railway).
SESSION_COOKIE_SECURE=true
